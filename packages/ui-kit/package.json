{
  "name": "@aryagg/ui-kit",
  "version": "0.0.1",
  "type": "module",

  "scripts": {
    "build": "svelte-package",
    "dev": "svelte-package -w",
    "prepack": "svelte-package && publint",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },

  "files": ["dist"],

  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },

  "dependencies": {
    "@aryagg/types": "workspace:*",
    "@aryagg/utils": "workspace:*"
  },

  "peerDependencies": {
    "svelte": "^5.0.0",
    "@sveltejs/kit": "^2.0.0",
    "svelte-bootstrap-icons": "^1.0.0"
  },

  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "publint": "^0.3.18"
  }
}
